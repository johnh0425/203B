\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Stage-by-stage optimal width allocation under three fixed wire profiles in the tuned operating regime. Concentrating more wire length near later stages changes the sizing pattern and tends to enlarge gates closer to the output side of the chain.}}{16}{}\protected@file@percent }
\newlabel{fig:width_profiles}{{2}{16}{}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Comparison between the full wire-aware model and a Boyd-style simplified baseline. The full model consistently yields a higher objective, indicating that neglecting wire effects underestimates the cost of meeting a timing target.}}{16}{}\protected@file@percent }
\newlabel{fig:baseline_compare}{{3}{16}{}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Optimal widths and wire lengths in the unrestricted formulation where both $W_i$ and $l_i$ are optimized. In the tested regime, both variables collapse to their lower bounds, revealing the degeneracy of the free-length formulation.}}{17}{}\protected@file@percent }
\newlabel{fig:free_length}{{4}{17}{}{figure.4}{}}
